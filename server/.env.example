# ============================================
# Configuration Serveur WiFi IUEs/INSAM
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# Port du serveur
PORT=3000

# FreeMoPay API v2
FREEMOPAY_APP_KEY=votre_app_key
FREEMOPAY_SECRET_KEY=votre_secret_key
FREEMOPAY_BASE_URL=https://api-v2.freemopay.com

# Mikrotik RouterOS API
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=votre_mot_de_passe

# Plans WiFi (format: id:profile_name:duration)
# Le profile_name doit correspondre aux User Profiles créés sur le Mikrotik
# La durée est au format Mikrotik (30m, 1h, 3h, 1d, 7d, 30d)
